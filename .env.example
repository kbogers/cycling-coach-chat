# Strava OAuth (https://www.strava.com/settings/api)
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
# Full URL (scheme required). Must match Strava app “Authorization Callback Domain” (e.g. localhost) and this exact path.
STRAVA_REDIRECT_URI=http://localhost:3000/api/auth/strava/callback

# Iron Session: min 32 characters (generate a random string)
SESSION_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# AES-256 key material: min 32 characters for encrypting Gemini keys at rest
ENCRYPTION_KEY=change-me-to-another-long-random-string-at-least-32-chars

# Optional: if Node fetch() fails with SELF_SIGNED_CERT_IN_CHAIN (AV HTTPS scanning, VPN, extra root CAs),
# append the PEM that should trust that chain: https://nodejs.org/api/cli.html#node_extra_ca_certsfile
# NODE_EXTRA_CA_CERTS=/absolute/path/to/extra-cas.pem
